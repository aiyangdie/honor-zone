# 数据库配置
DB_USER=game_user
DB_PASSWORD=game_password
DB_HOST=localhost
DB_NAME=game_leaderboard

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Flask（生产/局域网对外建议 FLASK_DEBUG=false）
FLASK_DEBUG=false
FLASK_PORT=5000

# 演示写入接口：新建战区、导入 seed（关闭后仅查询）
ENABLE_DEMO_API=true

# ---------- 王者荣耀战力 API ----------
HERO_API_PRIMARY=sapi
HERO_API_FALLBACK=xxoo
HERO_API_TIMEOUT=12

HERO_LIST_URL=https://www.sapi.run/hero/herolist.json
HERO_POWER_URL=https://www.sapi.run/hero/select.php
HERO_LIST_URL_FALLBACK=https://api.xxoo.team/hero/getHeroList.php
HERO_POWER_URL_FALLBACK=https://api.xxoo.team/hero/getHeroInfo.php

HERO_USE_OFFICIAL_LIST=true
HERO_OFFICIAL_LIST_URL=https://pvp.qq.com/web201605/js/herolist.json
